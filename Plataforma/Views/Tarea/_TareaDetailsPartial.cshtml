@model Plataforma.Models.Cursos.TareaDetailsViewModel

<link rel="stylesheet" href="~/css/curso/details.css" asp-append-version="true" />


<div class="tarea-details-container"
     id="current-tarea-details"
     data-deadline-blocked="@ViewBag.IsBlockedByDeadline.ToString().ToLower()">

    @{
        var statusClass = Model.SubmissionStatusText switch
        {
            "Aprobado" => "status-approved",
            "EnRevision" => "status-in-review",
            "En Progreso" => "status-in-progress",
            "Rehacer" => "status-redo",
            "Reprobado" => "status-rejected",
            _ => "status-unknown"
        };
    }

    <!-- HEADER -->

    <div class="task-header">

        <div>

            <a href="javascript:void(0);"
               data-class-id="@Model.ClaseId"
               onclick="loadClassDetailsFromTask(this, '@Model.ClaseId')"
               class="back-link">

                <i class="fa-solid fa-arrow-left"></i>

                Volver a la clase

            </a>

            <h1>@Model.Nombre</h1>

            @if (!string.IsNullOrWhiteSpace(Model.Descripcion)
                && Model.TipoContenido != "texto")
            {
                <p class="task-intro">

                    @Model.Descripcion

                </p>
            }

        </div>

    </div>

    <!-- MAIN LAYOUT -->

    <div class="task-layout">

        <!-- ========================= -->

        <!-- MAIN CONTENT -->

        <!-- ========================= -->

        <main class="task-main">

    @if (ViewBag.IsBlockedByDeadline)
{
    <div class="alert alert-danger">

        <i class="fa-solid fa-lock"></i>

        Esta actividad está bloqueada porque la fecha límite ha vencido.

    </div>
}

@if (Model.TipoContenido == "video"
    && !string.IsNullOrEmpty(Model.ContenidoUrl))
{
    <section class="content-card">

        <h2>Video</h2>

        <div class="video-player-container">

            <video id="my-video"
                   class="video-js vjs-default-skin vjs-big-play-centered"
                   controls
                   preload="auto"
                   data-setup='{}'
                   data-tarea-id="@Model.TareaId"
                   data-initial-time="@(ViewBag.InitialVideoTime ?? 0)"
                   data-completed="@(ViewBag.VideoCompleted?.ToString().ToLower() ?? "false")">

                <source src="@Model.ContenidoUrl"
                        type="video/mp4"/>

            </video>

        </div>

    </section>
}

else if (Model.TipoContenido == "Documento")
{
    <section class="content-card">

        <h2>Documento</h2>

        <p>

            Descarga el documento de esta actividad.

        </p>

        <a class="btn btn-primary"

           href="@Model.ContenidoUrl"

           target="_blank">

            <i class="fa-solid fa-file-arrow-down"></i>

            Abrir documento

        </a>

    </section>
}

else if (Model.TipoContenido == "lectura")
{
    <section class="content-card">

        <h2>Lectura</h2>

        <p>

            Consulta el material de lectura.

        </p>

        <a class="btn btn-primary"

           href="@Model.ContenidoUrl"

           target="_blank">

            <i class="fa-solid fa-book-open"></i>

            Abrir lectura

        </a>

    </section>
}

else if (Model.TipoContenido == "link")
{
    <section class="content-card">

        <h2>Enlace</h2>

        <p>
            Abre el siguiente enlace para acceder a la actividad.
        </p>

        <a class="btn btn-primary"
           href="@Model.UrlEntrega"
           target="_blank">

            <i class="fa-solid fa-up-right-from-square"></i>

            Abrir enlace

        </a>

    </section>
}

else if (Model.TipoContenido == "texto")
{
    <section class="content-card">

        @Html.Raw(Model.Descripcion)

    </section>
}

        </main>

        <!-- ========================= -->
        <!-- SIDEBAR -->
        <!-- ========================= -->

        <aside class="task-sidebar">

            <div class="info-card">

                <h3>Información</h3>

                @if (Model.TipoContenido == "Documento" ||
                        Model.TipoContenido == "video" ||
                        Model.TipoContenido == "link")
                {
                    <div class="info-row">
                        <i class="fa-regular fa-calendar"></i>

                        <div>

                            <span>Fecha límite</span>

                            <strong>

                                @Model.FechaLimite.Value.ToString("dd/MM/yyyy")

                            </strong>

                        </div>

                    </div>
                }

                @if (Model.FechaReunion.HasValue)
                {
                    <div class="info-row">

                        <i class="fa-solid fa-video"></i>

                        <div>

                            <span>Clase en vivo</span>

                            <strong>

                                @Model.FechaReunion.Value.ToString("dd/MM/yyyy HH:mm")

                            </strong>

                        </div>

                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.GrabacionUrl))
                {
                    <a href="@Model.GrabacionUrl"
                       target="_blank"
                       class="recording-card">

                        <i class="fa-solid fa-circle-play"></i>

                        <div>
                            <span class="recording-title">Grabación</span>
                            <small>Ver clase grabada</small>
                        </div>

                    </a>
                }

                @if (!string.IsNullOrEmpty(Model.ReunionUrl))
                {
                    <a href="@Model.ReunionUrl"
                       target="_blank"
                       class="btn btn-primary w-100 mt-3">

                        <i class="fa-solid fa-video"></i>

                        Unirse a la reunión

                    </a>
                }

            </div>

            <div class="info-card">

                <h3>Actividad</h3>

                <div class="info-row">

                    <i class="fa-solid fa-file-lines"></i>

                    <div>

                        <span>Tipo</span>

                        <strong>

                            <strong>
                                @(string.IsNullOrWhiteSpace(Model.TipoContenido)
                                    ? "-"
                                    : char.ToUpper(Model.TipoContenido[0]) + Model.TipoContenido.Substring(1).ToLower())
                            </strong>

                        </strong>

                    </div>

                </div>

                @if (Model.TipoContenido == "Documento" || Model.TipoContenido == "video")
                {
                    <div class="info-row">

                        <i class="fa-solid fa-circle-check"></i>

                        <div>

                            <span>Estado</span>


                            @if (Model.HasSubmitted)
                            {
                                <span class="badge @statusClass">

                                    @Model.SubmissionStatusText

                                </span>
                            }
                            else
                            {
                                <span class="badge status-in-progress">

                                    Pendiente

                                </span>
                            }

                        </div>

                    </div>
                }

            </div>

            @if (Model.HasSubmitted &&
                 Model.SubmissionFecha.HasValue)
            {
                <div class="info-card">

                    <h3>Última entrega</h3>

                    <p>

                        @Model.SubmissionFecha.Value.ToString("dd/MM/yyyy HH:mm")

                    </p>

                    @if (Model.TipoContenido == "link")
                    {
                        @if (!string.IsNullOrEmpty(Model.SubmittedUrl))
                        {
                            <div class="submission-row">

                                <strong>Enlace</strong>

                                <a href="@Model.SubmittedUrl"
                                   target="_blank">

                                    Abrir entrega

                                </a>

                            </div>
                        }
                    }
                    else
                    {
                        @if (!string.IsNullOrEmpty(Model.SubmittedFileUrl))
                    {
                        <div class="submission-row">
                            <strong>Archivo</strong>
                            <a href="@Model.SubmittedFileUrl" target="_blank">
                                Ver archivo entregado
                            </a>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.SubmittedUrl))
                    {
                        <div class="submission-row">
                            <strong>Enlace</strong>
                            <a href="@Model.SubmittedUrl" target="_blank">
                                Abrir entrega
                            </a>
                        </div>
                    }
                    }

                </div>
            }

        </aside>

    </div>


    @if (Model.TipoContenido != "texto" &&
     Model.TipoContenido != "lectura")
{
    <section class="submission-card">

        <div class="submission-header">

            <div>

                <h2>Tu entrega</h2>

                <p>

                    Envía tu trabajo o revisa el estado de tu entrega.

                </p>

            </div>

            @if (Model.HasSubmitted)
            {
                <span class="badge @statusClass">

                    @Model.SubmissionStatusText

                </span>
            }

        </div>

        <hr />

        @if (Model.HasSubmitted)
        {

            @if (Model.SubmissionFecha.HasValue)
            {
                <div class="submission-row">

                    <strong>Fecha de entrega</strong>

                    <span>

                        @Model.SubmissionFecha.Value.ToString("dd/MM/yyyy HH:mm")

                    </span>

                </div>
            }

            @if (!string.IsNullOrEmpty(Model.SubmittedFileUrl))
            {
                <div class="submission-row">

                    <strong>Archivo</strong>

                    <a href="@Model.SubmittedFileUrl"
                       target="_blank">

                        Ver archivo entregado

                    </a>

                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.SubmissionComentarios))
            {

                <div class="teacher-feedback @statusClass">

                    <h3>

                        <i class="fa-solid fa-comments"></i>

                        Comentarios del profesor

                    </h3>

                    <p>

                        @Model.SubmissionComentarios

                    </p>

                </div>

            }

            @if (Model.SubmissionStatusText == "Rehacer"
                 && !ViewBag.IsBlockedByDeadline)
            {

                <button class="btn btn-warning mt-3"

                        onclick="showSubmissionForm('@Model.TareaId')">

                    <i class="fa-solid fa-rotate-right"></i>

                    Rehacer entrega

                </button>

            }

        }
        else
        {

            @if (ViewBag.IsBlockedByDeadline)
            {

                <div class="alert alert-danger">

                    <i class="fa-solid fa-lock"></i>

                    La fecha límite venció.

                </div>

            }
            else
            {

                <div class="empty-submission">

                    <i class="fa-solid fa-cloud-arrow-up"></i>

                    <h3>

                        Todavía no entregaste esta actividad

                    </h3>

                    <p>
                        @if (Model.TipoContenido == "link")
                        {
                            <text>Cuando termines, envía el enlace de tu trabajo.</text>
                        }
                        else
                        {
                            <text>Cuando termines, envía tu archivo aquí.</text>
                        }
                    </p>

                    <button class="btn btn-primary"

                            onclick="showSubmissionForm('@Model.TareaId')">

                        Entregar actividad

                    </button>

                </div>

            }

        }

        <div id="submission-form-container-@Model.TareaId"
             class="submission-form"
             style="display:none;">

            <div class="submission-form-card">

                <div class="submission-form-header">

                    <i class="fa-solid fa-cloud-arrow-up"></i>

                    <div>
                        <h3>Enviar entrega</h3>
                        <p>Completa la información y envía tu trabajo.</p>
                    </div>

                </div>

                <form id="submissionForm-@Model.TareaId"
                      enctype="multipart/form-data">

                    @Html.AntiForgeryToken()

                    <input type="hidden"
                           name="TareaId"
                           value="@Model.TareaId" />

                    @if (Model.TipoContenido == "link")
                    {
                        <div class="submission-field">

                            <label>Enlace</label>

                            <input type="url"
                                   class="submission-input"
                                   name="SubmittedUrl"
                                   placeholder="https://..."
                                   required />

                            <small>Pega aquí el enlace de tu trabajo.</small>

                        </div>
                    }
                    else
                    {
                        <div class="submission-field">

                            <label>Archivo</label>

                            <input type="file"
                                   class="submission-input"
                                   name="SubmittedFile"
                                   accept=".pdf,.doc,.docx,.xls,.xlsx" />

                            <small>Sube un archivo o completa el enlace abajo</small>

                        </div>

                        <div class="submission-field">

                            <label>Enlace</label>

                            <input type="url"
                                   class="submission-input"
                                   name="SubmittedUrl"
                                   placeholder="https://..." />

                        </div>
                    }

                    <div class="submission-actions">

                        <button class="submit-btn"
                                type="submit">

                            <i class="fa-solid fa-paper-plane"></i>

                            Enviar entrega

                        </button>

                        <button class="cancel-btn"
                                type="button"
                                onclick="hideSubmissionForm('@Model.TareaId')">

                            Cancelar

                        </button>

                    </div>

                </form>

                <div id="submission-message-@Model.TareaId"></div>

            </div>

        </div>

    </section>
}

</div>

<script>
    const isBlocked = document
    .getElementById("current-tarea-details")
    ?.dataset.deadlineBlocked === "true";
</script>