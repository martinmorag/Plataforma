@model Plataforma.Models.Administracion.AdministracionViewModel

@{
    ViewData["Title"] = "Editar Estudiante";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/administrador/estudiantes/editar.css" asp-append-version="true" />

<div class="container-custom">

    <h1>Editar Estudiante</h1>

    <hr />
    <div>
        <form asp-controller="Estudiantes" asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="EstudianteAEditar.Id" />

            <div class="form-group">
                <label asp-for="EstudianteAEditar.Nombre" class="control-label"></label>
                <input asp-for="EstudianteAEditar.Nombre" class="form-control" />
                <span asp-validation-for="EstudianteAEditar.Nombre" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="EstudianteAEditar.Apellido" class="control-label"></label>
                <input asp-for="EstudianteAEditar.Apellido" class="form-control" />
                <span asp-validation-for="EstudianteAEditar.Apellido" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="EstudianteAEditar.Email" class="control-label"></label>
                <input asp-for="EstudianteAEditar.Email" class="form-control" />
                <span asp-validation-for="EstudianteAEditar.Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Guardar Cambios" class="btn btn-primary" />
            </div>
        </form>
    </div>
    <hr />

    <h5>Seguridad de la cuenta</h5>

    <a asp-controller="Estudiantes"
    asp-action="GenerarResetearContraseña"
    asp-route-id="@Model.EstudianteAEditar.Id"
    class="btn-reset-password">
        🔑 Generar enlace para restablecer contraseña
    </a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}