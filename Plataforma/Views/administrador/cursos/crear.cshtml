@model Plataforma.Models.Administracion.CursoAdminIndexViewModel;

@{
    ViewData["Title"] = "Crear Curso";
    Layout = "_Layout";
}

<div class="form-container">
    <h2>Crear Nuevo Curso</h2>

    <form asp-action="CrearCurso"
          method="post"
          enctype="multipart/form-data">

        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly"></div>

        <div class="form-group">
            <label asp-for="Nombre"></label>
            <input asp-for="Nombre" class="form-input" />
            <span asp-validation-for="Nombre"></span>
        </div>

        <div class="form-group">
            <label>Imagen del Curso (opcional)</label>
            <input type="file" name="imagenCurso" accept="image/*" />
        </div>

        <div class="form-group">
            <label>
                <input asp-for="Habilitado" type="checkbox" />
                Curso Disponible
            </label>
        </div>

        <button type="submit">Crear Curso</button>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}