@model Plataforma.Models.Administracion.CrearCursoViewModel

@{
    ViewData["Title"] = "Editar Curso";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/administrador/cursos/crear.css" asp-append-version="true" />

<div class="create-course-wrapper">

    <div class="create-course-card">

        <div class="card-header">
            <h2>Editar Curso</h2>
            <p>Modifica la información del curso.</p>
        </div>

        <form asp-action="EditarCurso"
              asp-route-id="@ViewBag.CursoId"
              method="post"
              enctype="multipart/form-data"
              class="course-form">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <!-- Nombre -->
            <div class="form-group">
                <label asp-for="Nombre"></label>
                <input asp-for="Nombre"
                       class="form-control-custom"
                       placeholder="Nombre del curso" />
                <span asp-validation-for="Nombre" class="field-validation"></span>
            </div>

            <!-- Imagen actual -->
            @if (ViewBag.ImageUrl != null)
            {
                <div class="form-group">
                    <label>Imagen Actual</label>
                    <div class="image-preview-wrapper">
                        <img src="@ViewBag.ImageUrl"
                             alt="Imagen Curso"
                             class="image-preview" />
                    </div>
                </div>
            }

            <!-- Reemplazar imagen -->
            <div class="form-group">
                <label>Reemplazar Imagen (opcional)</label>
                <div class="file-input-wrapper">
                    <input type="file" name="imagenCurso" accept="image/*" />
                </div>
            </div>

            <div class="form-group switch-group">
                <label class="switch">
                    <input asp-for="Disponible" type="checkbox" />
                    <span class="slider"></span>
                </label>
                <span class="switch-label">Curso Disponible</span>
            </div>

            <div class="form-actions">
                <a asp-controller="administrador"
                       asp-action="Index"
                       class="btn-secondary">
                    Cancelar
                </a>

                <button type="submit" class="btn-primary">
                    Guardar Cambios
                </button>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}