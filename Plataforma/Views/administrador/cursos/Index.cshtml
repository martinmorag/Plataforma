@model List<Plataforma.Models.Administracion.CursoAdminIndexViewModel>

@{
    ViewData["Title"] = "Administrar Cursos";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/administrador/cursos/index.css" asp-append-version="true" />

<div class="admin-container">
    <div class="admin-header">
        <h2>Gestión de Cursos</h2>
        <span class="course-count">@Model.Count cursos</span>
    </div>

    <div class="courses-grid">
        @foreach (var curso in Model)
        {
            <div class="course-card">

                <div class="course-content">

                    <div class="course-header">
                        <h3>@curso.Nombre</h3>

                        <span class="status-badge @(curso.Habilitado ? "enabled" : "disabled")">
                            @(curso.Habilitado ? "Habilitado" : "No habilitado")
                        </span>
                    </div>

                    <div class="course-section">
                        <span class="section-label">Estudiantes</span>
                        <span class="students-count">@curso.CantidadEstudiantes</span>
                    </div>

                    <div class="course-section">
                        <span class="section-label">Profesores</span>

                        @if (curso.Profesores.Any())
                        {
                            <ul class="custom-list">
                                @foreach (var profesor in curso.Profesores)
                                {
                                    <li>👨‍🏫 @profesor</li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="empty">No asignados</p>
                        }
                    </div>

                    <div class="course-section">
                        <span class="section-label">Módulos</span>

                        @if (curso.Modulos.Any())
                        {
                            @foreach (var modulo in curso.Modulos)
                            {
                                <div class="module-box">
                                    <strong>📘 @modulo.Nombre</strong>

                                    @if (modulo.Clases.Any())
                                    {
                                        <ul class="custom-list small">
                                            @foreach (var clase in modulo.Clases)
                                            {
                                                <li>📖 @clase</li>
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        <p class="empty small">Sin clases</p>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <p class="empty">Sin módulos</p>
                        }
                    </div>

                </div>

                <div class="course-actions">

                    <!-- Enable / Disable -->
                    <button type="button"
                            class="btn-toggle @(curso.Habilitado ? "disable" : "enable")"
                            data-id="@curso.CursoId"
                            onclick="toggleCurso(this)">
                        @(curso.Habilitado ? "Deshabilitar" : "Habilitar")
                    </button>

                    <a asp-action="EditarCurso"
                           asp-route-id="@curso.CursoId"
                           class="btn-edit">
                        Editar
                    </a>

                    <button type="button"
                            class="btn-delete"
                            onclick="confirmDelete('@curso.CursoId', '@curso.Nombre')">
                        Eliminar
                    </button>

                </div>

            </div>
        }
    </div>
</div>


<form id="deleteForm"
      method="post"
      style="display:none;">
    @Html.AntiForgeryToken()
</form>


<script src="~/js/administrador/cursos/index.js" asp-append-version="true"></script>