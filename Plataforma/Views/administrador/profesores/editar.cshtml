@model Plataforma.Models.Administracion.AdministracionViewModel

@{
    ViewData["Title"] = "Editar Profesor";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/administrador/profesores/editar.css" asp-append-version="true" />


<div class="container-custom">
    <h1 class="page-title">Editar Profesor</h1>

    <hr />
    <div>
        <form asp-controller="Profesores" asp-action="Edit" method="post" class="app-form">
            <div asp-validation-summary="ModelOnly" class="text-danger-summary"></div>
            <input type="hidden" asp-for="ProfesorAEditar.Id" />

            <div class="form-group">
                <label asp-for="ProfesorAEditar.Nombre" class="control-label"></label>
                <input asp-for="ProfesorAEditar.Nombre" class="form-control" />
                <span asp-validation-for="ProfesorAEditar.Nombre" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ProfesorAEditar.Apellido" class="control-label"></label>
                <input asp-for="ProfesorAEditar.Apellido" class="form-control" />
                <span asp-validation-for="ProfesorAEditar.Apellido" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ProfesorAEditar.Email" class="control-label"></label>
                <input asp-for="ProfesorAEditar.Email" class="form-control" />
                <span asp-validation-for="ProfesorAEditar.Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Guardar Cambios" class="btn btn-primary" />
            </div>
        </form>
    </div>
    <hr />

    <h5>Seguridad de la cuenta</h5>

    <a asp-controller="Estudiantes"
    asp-action="GenerarResetearContraseña"
    asp-route-id="@Model.EstudianteAEditar.Id"
    class="btn-reset-password">
        🔑 Generar enlace para restablecer contraseña
    </a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}