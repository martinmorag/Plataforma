@model Plataforma.Models.Profesores.EditarTareaViewModel

@{
    ViewData["Title"] = "Editar Tarea";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/tareas/crear.css" asp-append-version="true" />

<div class="form-container">
    <h2 class="form-title">
        Editar Tarea para
        <span class="class-name">@Model.ClaseNombre</span>
    </h2>

    <div class="form-card">
        <h4 class="card-header">Detalles de la Tarea</h4>
        <hr class="divider" />

        <form asp-controller="tareas"
              asp-action="Editar"
              method="post"
              enctype="multipart/form-data">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <input type="hidden" asp-for="TareaId" />
            <input type="hidden" asp-for="ClaseId" />

            <div class="form-group">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-input" />
                <span asp-validation-for="Nombre" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Descripcion" class="form-label"></label>
                <textarea asp-for="Descripcion"
                          class="form-textarea"
                          rows="3"></textarea>
                <span asp-validation-for="Descripcion" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="ReunionUrl" class="form-label">URL de la Reunión (opcional)</label>
                <input asp-for="ReunionUrl" class="form-input" />
                <span asp-validation-for="ReunionUrl" class="validation-error"></span>
            </div>

            <div class="mb-3">
                <label asp-for="FechaReunion" class="form-label">Fecha de Reunión</label>
                <input asp-for="FechaReunion" type="datetime-local" class="form-control" />
                <span asp-validation-for="FechaReunion" class="text-danger"></span>
            </div>

            <div class="form-group" id="entregaUrlGroup">
                <label asp-for="UrlEntrega" class="form-label">URL de la Tarea</label>
                <input asp-for="UrlEntrega" class="form-input" />
                <span asp-validation-for="UrlEntrega" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="GrabacionUrl" class="form-label">
                    Link de grabación
                </label>

                <input asp-for="GrabacionUrl"
                       class="form-control"
                       placeholder="https://..." />
            </div>

            <div class="form-group" id="fechaVencimientoGroup">
                <label asp-for="FechaVencimiento" class="form-label">Fecha de Vencimiento</label>
                <input asp-for="FechaVencimiento"
                   type="datetime-local"
                   class="form-input"
                   value="@(Model.FechaVencimiento?.ToString("yyyy-MM-ddTHH:mm"))" />
                <span asp-validation-for="FechaVencimiento" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="TipoEntregaEsperado" class="form-label">Tipo de Entrega Esperado</label>
                <select asp-for="TipoEntregaEsperado" id="TipoEntregaEsperado" class="form-input">
                    <option value="lectura">Lectura</option>
                    <option value="Documento">Documento</option>
                    <option value="link">Enlace (URL)</option>
                    <option value="video">Video</option>
                    <option value="texto">Texto</option>
                </select>
                <span asp-validation-for="TipoEntregaEsperado" class="validation-error"></span>
            </div>

            @if (Model.ArchivoNombre != null)
            {
                <div class="form-group">
                    <label class="form-label">Archivo Actual</label>
                    <div style="margin-bottom:10px;">
                        <strong>@Model.ArchivoNombre</strong>
                    </div>
                </div>
            }

            <div class="form-group">
                <label class="form-label">
                    Reemplazar archivo (opcional)
                </label>
                <input type="file"
                       name="nuevoArchivo"
                       class="form-input"
                       accept=".pdf,.doc,.docx,.xls,.xlsx,video/*" />
                <span class="validation-error">
                    @ViewData.ModelState["nuevoArchivo"]?.Errors.FirstOrDefault()?.ErrorMessage
                </span>
            </div>

            <div class="form-actions">
                <button type="submit" class="submit-button">
                    Guardar Cambios
                </button>

                <a asp-action="MisCursosYTareas"
                       asp-route-cursoId="@Model.CursoId"
                       class="return-link">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

<script src="~/js/tareas/editar.js" asp-append-version="true"></script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}